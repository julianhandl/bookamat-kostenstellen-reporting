# Bookamat API defaults — used when the UI doesn't supply a value.
# Copy this file to `.env` and fill in your own values. Bun auto-loads `.env`.

# Bookamat account username (the one you log in with).
BOOKAMAT_USERNAME=

# Personal API key generated in Bookamat's account settings.
BOOKAMAT_API_KEY=

# Lowercase ISO country code, e.g. `at` for Austria.
BOOKAMAT_COUNTRY=at

# Reporting year, e.g. 2026.
BOOKAMAT_YEAR=2026
